library(rpart)
library(rpart.plot)
library(ggplot2)
library(dplyr)
# Wczytaj dane
df <- read.csv("D:\\Projekty\\praca_licencjacka\\Projekt-Formacje-roslinne-na-terenach-pustynniejacych\\folder_na_modele\\wygenerowane_dane_100k.csv")
# ============================================================
# 1. DRZEWO ŚREDNIE (do prezentacji)
# ============================================================
tree_v2 <- rpart(pattern_name ~ a + m + d1 + d2,
data = df,
method = "class",
control = rpart.control(
maxdepth = 6,
minsplit = 200,
minbucket = 100,
cp = 0.001
))
# Zapisz drzewo
png("drzewo_srednie.png", width = 5000, height = 4000, res = 300)
rpart.plot(tree_v2,
type = 2,
extra = 104,
under = TRUE,
fallen.leaves = FALSE,
cex = 0.8,
tweak = 1.0,
gap = 0.5,
space = 0.5,
branch = 0.5,
main = "Drzewo decyzyjne - przewidywanie wzorów roślinnych")
dev.off()
cat("✅ Zapisano 'drzewo_srednie.png'\n")
# ============================================================
# 2. WYKRES a vs m (rozkład wzorów)
# ============================================================
p <- ggplot(df %>% sample_n(5000), aes(x = a, y = m, color = pattern_name)) +
geom_point(alpha = 0.5, size = 1.5) +
labs(title = "Rozkład wzorów w przestrzeni opady (a) vs śmiertelność (m)",
x = "a (opady)",
y = "m (śmiertelność)",
color = "Wzór") +
theme_minimal(base_size = 14) +
theme(legend.position = "bottom")
ggsave("wykres_a_vs_m.png", plot = p, width = 10, height = 8, dpi = 300)
cat("✅ Zapisano 'wykres_a_vs_m.png'\n")
p
# ============================================================
# 3. DOKŁADNOŚCI TRZECH WERSJI DRZEWA
# ============================================================
# Proste
tree_v1 <- rpart(pattern_name ~ a + m + d1 + d2,
data = df,
method = "class",
control = rpart.control(maxdepth = 4, minsplit = 500, cp = 0.001))
# Średnie (już jest)
# Oryginalne
tree_v3 <- rpart(pattern_name ~ a + m + d1 + d2,
data = df,
method = "class",
control = rpart.control(minsplit = 100, cp = 0.001, maxdepth = 10))
pred_v1 <- predict(tree_v1, df, type = "class")
acc_v1 <- mean(pred_v1 == df$pattern_name)
pred_v2 <- predict(tree_v2, df, type = "class")
acc_v2 <- mean(pred_v2 == df$pattern_name)
pred_v3 <- predict(tree_v3, df, type = "class")
acc_v3 <- mean(pred_v3 == df$pattern_name)
# Tabela dokładności
acc_table <- data.frame(
Wersja = c("Prosta (maxdepth=4)", "Średnia (maxdepth=6)", "Oryginalna (maxdepth=10)"),
Dokladnosc = c(round(acc_v1 * 100, 1), round(acc_v2 * 100, 1), round(acc_v3 * 100, 1)),
Liscie = c(sum(tree_v1$frame$var == "<leaf>"),
sum(tree_v2$frame$var == "<leaf>"),
sum(tree_v3$frame$var == "<leaf>"))
)
cat("\n========================================================\n")
cat("PODSUMOWANIE DOKŁADNOŚCI\n")
cat("========================================================\n")
print(acc_table)
# Zapisz tabelę
write.csv(acc_table, "dokladnosci.csv", row.names = FALSE)
cat("✅ Zapisano 'dokladnosci.csv'\n")
# ============================================================
# 4. PROSTA INSTRUKCJA OBSŁUGI DRZEWA (do prezentacji)
# ============================================================
cat("\n========================================================\n")
cat("JAK CZYTAĆ DRZEWO:\n")
cat("========================================================\n")
cat("1. Zaczynasz od góry (korzeń)\n")
cat("2. Zadajesz pytanie - jeśli TAK idziesz w lewo, jeśli NIE w prawo\n")
cat("3. Powtarzasz aż dojdziesz do liścia (prostokąt)\n")
cat("4. W liściu odczytujesz przewidywany wzór\n")
cat("\nPrzykład:\n")
cat("  a = 1.0 → idziesz w lewo → PUSTYNIA\n")
cat("  a = 2.5, m = 0.4 → prawo → prawo → PLAMY\n")
cat("  a = 3.0, m = 0.2 → prawo → lewo → LABIRYNT\n")
cat("\n✅ Analiza zakończona!\n")
pred_v1
